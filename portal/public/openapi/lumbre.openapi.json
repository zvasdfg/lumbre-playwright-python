{
  "openapi": "3.1.1",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "Lumbre API",
    "version": "1.0.0",
    "description": "Contract for the Lumbre system under test. Mutation operations are available only in development and test; production returns 405 and remains read-only."
  },
  "servers": [{ "url": "/", "description": "Current Lumbre environment" }],
  "tags": [
    { "name": "System" },
    { "name": "Catalog" },
    { "name": "Laboratory" },
    { "name": "Test support" }
  ],
  "paths": {
    "/api": {
      "get": {
        "operationId": "discoverApi",
        "tags": ["System"],
        "responses": {
          "200": { "$ref": "#/components/responses/ApiIndexResponse" }
        }
      }
    },
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "tags": ["System"],
        "responses": {
          "200": { "$ref": "#/components/responses/HealthResponse" }
        }
      }
    },
    "/api/recipes": {
      "get": {
        "operationId": "listRecipes",
        "tags": ["Catalog"],
        "parameters": [
          { "$ref": "#/components/parameters/RecipeCategory" },
          { "$ref": "#/components/parameters/SearchQuery" }
        ],
        "responses": {
          "200": {
            "description": "Filtered recipe collection",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/RecipeCollection" } }
            }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "operationId": "listProducts",
        "tags": ["Catalog"],
        "responses": {
          "200": {
            "description": "Product collection",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductCollection" } }
            }
          }
        }
      },
      "post": {
        "operationId": "createProduct",
        "tags": ["Catalog"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/ProductCreateRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Product representation created in the demonstration API",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductCreateResponse" } }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationErrorResponse" },
          "405": { "$ref": "#/components/responses/ReadOnlyResponse" }
        }
      }
    },
    "/api/events": {
      "get": {
        "operationId": "listEvents",
        "tags": ["Catalog"],
        "responses": {
          "200": {
            "description": "Event collection",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/EventCollection" } }
            }
          }
        }
      }
    },
    "/api/members": {
      "post": {
        "operationId": "createMember",
        "tags": ["Catalog"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/MemberCreateRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Membership registration accepted in a mutable environment",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/MemberCreateResponse" } }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationErrorResponse" },
          "405": { "$ref": "#/components/responses/ReadOnlyResponse" }
        }
      }
    },
    "/api/ingredientes": {
      "get": {
        "operationId": "getIngredients",
        "tags": ["Laboratory"],
        "parameters": [
          { "$ref": "#/components/parameters/IngredientId" },
          { "$ref": "#/components/parameters/IngredientFamily" },
          { "$ref": "#/components/parameters/IngredientStatus" },
          { "$ref": "#/components/parameters/SearchQuery" }
        ],
        "responses": {
          "200": {
            "description": "Ingredient detail when id is present, otherwise a filtered collection",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/IngredientDetail" },
                    { "$ref": "#/components/schemas/IngredientCollection" }
                  ]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundResponse" }
        }
      }
    },
    "/api/hipotesis": {
      "get": {
        "operationId": "listHypotheses",
        "tags": ["Laboratory"],
        "responses": {
          "200": {
            "description": "Technical-sheet registry",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/HypothesisCollection" } }
            }
          },
          "500": { "$ref": "#/components/responses/ServerErrorResponse" }
        }
      },
      "post": {
        "operationId": "createHypothesis",
        "tags": ["Laboratory"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/HypothesisCreateRequest" } }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/HypothesisMutationResponse" },
          "201": { "$ref": "#/components/responses/HypothesisMutationResponse" },
          "400": { "$ref": "#/components/responses/ValidationErrorResponse" },
          "422": { "$ref": "#/components/responses/HypothesisValidationResponse" },
          "405": { "$ref": "#/components/responses/ReadOnlyResponse" },
          "500": { "$ref": "#/components/responses/ServerErrorResponse" }
        }
      }
    },
    "/api/hipotesis/{id}": {
      "get": {
        "operationId": "getHypothesis",
        "tags": ["Laboratory"],
        "parameters": [{ "$ref": "#/components/parameters/HypothesisId" }],
        "responses": {
          "200": {
            "description": "One technical sheet",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/HypothesisDetail" } }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundResponse" },
          "500": { "$ref": "#/components/responses/ServerErrorResponse" }
        }
      }
    },
    "/api/test/reset": {
      "post": {
        "operationId": "resetTestData",
        "tags": ["Test support"],
        "description": "Test-only hook. Development and production conceal it with 404.",
        "responses": {
          "200": {
            "description": "Test fixture reset acknowledgement",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ResetResponse" } }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundResponse" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "SearchQuery": {
        "name": "q",
        "in": "query",
        "required": false,
        "schema": { "type": "string" }
      },
      "RecipeCategory": {
        "name": "category",
        "in": "query",
        "required": false,
        "schema": { "type": "string", "enum": ["todos", "directo", "lento", "vegetales"] }
      },
      "IngredientId": {
        "name": "id",
        "in": "query",
        "required": false,
        "schema": { "type": "string", "pattern": "^[a-z0-9_]+$" }
      },
      "IngredientFamily": {
        "name": "familia",
        "in": "query",
        "required": false,
        "schema": { "type": "string" }
      },
      "IngredientStatus": {
        "name": "estado",
        "in": "query",
        "required": false,
        "schema": { "type": "string" }
      },
      "HypothesisId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "pattern": "^LH[CBVP]-[0-9]{3}$" }
      }
    },
    "responses": {
      "ApiIndexResponse": {
        "description": "API discovery document adapted to the active environment",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ApiIndex" } }
        }
      },
      "HealthResponse": {
        "description": "Service health",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Health" } }
        }
      },
      "NotFoundResponse": {
        "description": "Resource or concealed test route was not found",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      },
      "ValidationErrorResponse": {
        "description": "Request validation failed",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      },
      "ReadOnlyResponse": {
        "description": "Mutation blocked by production read-only policy",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      },
      "ServerErrorResponse": {
        "description": "Registry operation failed",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/DetailedError" } }
        }
      },
      "HypothesisMutationResponse": {
        "description": "A new or deduplicated technical sheet",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/HypothesisMutation" } }
        }
      },
      "HypothesisValidationResponse": {
        "description": "Formula validation diagnostics",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/HypothesisValidationError" } }
        }
      }
    },
    "schemas": {
      "ApiIndex": {
        "type": "object",
        "required": ["name", "version", "environment", "access", "endpoints"],
        "properties": {
          "name": { "const": "Lumbre API" },
          "version": { "type": "string" },
          "environment": { "type": "string", "enum": ["development", "test", "production"] },
          "access": { "type": "string", "enum": ["read-only", "read-write"] },
          "endpoints": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        },
        "additionalProperties": false
      },
      "Health": {
        "type": "object",
        "required": ["status", "service", "seedVersion", "timestamp"],
        "properties": {
          "status": { "const": "ok" },
          "service": { "const": "lumbre-api" },
          "seedVersion": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      },
      "Recipe": {
        "type": "object",
        "required": ["id", "title", "category", "categoryLabel", "time", "level", "description", "tone"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["directo", "lento", "vegetales"] },
          "categoryLabel": { "type": "string", "minLength": 1 },
          "time": { "type": "string", "minLength": 1 },
          "level": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "tone": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "Product": {
        "type": "object",
        "required": ["id", "name", "category", "price"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["ropa", "herramientas", "outdoor"] },
          "price": { "type": "number", "exclusiveMinimum": 0 },
          "badge": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "Event": {
        "type": "object",
        "required": ["id", "day", "month", "city", "title", "detail", "spots"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "day": { "type": "string", "pattern": "^[0-9]{2}$" },
          "month": { "type": "string", "minLength": 3 },
          "city": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 },
          "spots": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "CountedCollection": {
        "type": "object",
        "required": ["data", "count"],
        "properties": {
          "data": { "type": "array" },
          "count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "RecipeCollection": {
        "allOf": [
          { "$ref": "#/components/schemas/CountedCollection" },
          { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Recipe" } } } }
        ]
      },
      "ProductCollection": {
        "allOf": [
          { "$ref": "#/components/schemas/CountedCollection" },
          { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } } } }
        ]
      },
      "EventCollection": {
        "allOf": [
          { "$ref": "#/components/schemas/CountedCollection" },
          { "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } } } }
        ]
      },
      "Source": {
        "type": "object",
        "required": ["titulo", "url"],
        "properties": {
          "titulo": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      },
      "IngredientExperiment": {
        "type": "object",
        "required": ["id", "estado", "objetivo", "hipotesis", "metodo", "variables_controladas", "metricas"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "estado": { "type": "string", "minLength": 1 },
          "objetivo": { "type": "string", "minLength": 1 },
          "hipotesis": { "type": "string", "minLength": 1 },
          "metodo": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "variables_controladas": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "metricas": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      },
      "Ingredient": {
        "type": "object",
        "required": ["id", "nombre", "familia", "estado", "descripcion", "origen", "disponibilidad_mexico", "granularidad_recomendada", "granularidades_probadas", "perfil_sensorial", "compuestos_principales", "comportamiento_termico", "compatibilidad", "aporte", "dosificacion", "estabilidad", "proveedores", "bibliografia", "experimentos", "notas_laboratorio"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "nombre": { "type": "string", "minLength": 1 },
          "familia": { "type": "string", "minLength": 1 },
          "estado": { "type": "string", "minLength": 1 },
          "descripcion": { "type": "string", "minLength": 1 },
          "origen": { "type": "string", "minLength": 1 },
          "disponibilidad_mexico": { "type": "string", "minLength": 1 },
          "granularidad_recomendada": { "type": "string", "minLength": 1 },
          "granularidades_probadas": { "type": "array", "items": { "type": "string" } },
          "perfil_sensorial": { "type": "object", "additionalProperties": { "type": ["number", "null"] } },
          "compuestos_principales": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "comportamiento_termico": {
            "type": "object",
            "required": ["liberacion_aromatica", "degradacion", "comentarios"],
            "properties": {
              "liberacion_aromatica": { "type": "string" },
              "degradacion": { "type": "string" },
              "comentarios": { "type": "string" }
            },
            "additionalProperties": false
          },
          "compatibilidad": { "type": "object", "additionalProperties": { "type": ["number", "null"] } },
          "aporte": { "type": "object", "additionalProperties": { "type": ["number", "null"] } },
          "dosificacion": {
            "type": "object",
            "required": ["minimo", "recomendado", "maximo"],
            "properties": {
              "minimo": { "type": "string" },
              "recomendado": { "type": "string" },
              "maximo": { "type": "string" }
            },
            "additionalProperties": false
          },
          "estabilidad": { "type": "object", "additionalProperties": { "type": "string" } },
          "proveedores": { "type": "array", "items": { "type": "string" } },
          "bibliografia": { "type": "array", "items": { "$ref": "#/components/schemas/Source" } },
          "experimentos": { "type": "array", "items": { "$ref": "#/components/schemas/IngredientExperiment" } },
          "notas_laboratorio": { "type": "string" }
        },
        "additionalProperties": false
      },
      "IngredientDetail": {
        "type": "object",
        "required": ["data"],
        "properties": { "data": { "$ref": "#/components/schemas/Ingredient" } },
        "additionalProperties": false
      },
      "IngredientCollection": {
        "type": "object",
        "required": ["data", "count", "total", "families"],
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Ingredient" } },
          "count": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "families": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        },
        "additionalProperties": false
      },
      "FormulaSource": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      },
      "Hypothesis": {
        "type": "object",
        "required": ["schema_version", "id", "firma", "objetivo", "componentes", "hipotesis", "formula", "perfil_esperado", "metodo", "estado", "contador_repeticiones", "creado_en"],
        "properties": {
          "schema_version": { "const": 5 },
          "id": { "type": "string", "pattern": "^LH[CBVP]-[0-9]{3}$" },
          "firma": { "type": "string", "pattern": "^LH[CBVP]:" },
          "objetivo": { "$ref": "#/components/schemas/HypothesisObjective" },
          "componentes": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "$ref": "#/components/schemas/HypothesisComponent" } },
          "hipotesis": { "type": "string", "minLength": 1 },
          "formula": { "$ref": "#/components/schemas/FormulaEvidence" },
          "perfil_esperado": { "type": "array", "items": { "$ref": "#/components/schemas/ExpectedProfile" } },
          "metodo": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "estado": { "type": "string", "enum": ["borrador", "recomendado_sin_validar"] },
          "tipo_registro": { "type": "string", "enum": ["hipotesis_usuario", "recomendacion_investigada"] },
          "recomendacion": { "$ref": "#/components/schemas/Recommendation" },
          "contador_repeticiones": { "type": "integer", "minimum": 0 },
          "creado_en": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      },
      "HypothesisObjective": {
        "type": "string",
        "enum": ["Costra para res", "Bark para cocción lenta", "Vegetales a las brasas", "Pollo al fuego directo"]
      },
      "HypothesisComponent": {
        "type": "object",
        "required": ["id", "nombre", "familia"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "nombre": { "type": "string", "minLength": 1 },
          "familia": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "FormulaEvidence": {
        "type": "object",
        "required": ["level", "formula_id", "formula_name", "conclusion", "matched_roles", "missing_roles", "additional_profiles", "sources"],
        "properties": {
          "level": { "type": "string", "enum": ["referenced", "close", "experimental"] },
          "formula_id": { "type": ["string", "null"] },
          "formula_name": { "type": "string", "minLength": 1 },
          "conclusion": { "type": "string", "minLength": 1 },
          "matched_roles": { "type": "array", "items": { "type": "string" } },
          "missing_roles": { "type": "array", "items": { "type": "string" } },
          "additional_profiles": { "type": "array", "items": { "$ref": "#/components/schemas/AdditionalProfile" } },
          "sources": { "type": "array", "items": { "$ref": "#/components/schemas/FormulaSource" } }
        },
        "additionalProperties": false
      },
      "AdditionalProfile": {
        "type": "object",
        "required": ["role", "ingredients", "contribution"],
        "properties": {
          "role": { "type": "string" },
          "ingredients": { "type": "array", "items": { "type": "string" } },
          "contribution": { "type": "string" }
        },
        "additionalProperties": false
      },
      "ExpectedProfile": {
        "type": "object",
        "required": ["attribute", "intensity", "ingredients"],
        "properties": {
          "attribute": { "type": "string" },
          "intensity": { "type": "number", "minimum": 0 },
          "ingredients": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "Recommendation": {
        "type": "object",
        "required": ["id", "nombre", "fundamento", "adaptacion", "proporciones", "fuentes"],
        "properties": {
          "id": { "type": "string" },
          "nombre": { "type": "string" },
          "fundamento": { "type": "string" },
          "adaptacion": { "type": "string" },
          "proporciones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ingrediente_id", "partes"],
              "properties": {
                "ingrediente_id": { "type": "string" },
                "partes": { "type": "number", "exclusiveMinimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "fuentes": { "type": "array", "items": { "$ref": "#/components/schemas/Source" } }
        },
        "additionalProperties": false
      },
      "HypothesisCollection": {
        "type": "object",
        "required": ["data", "count"],
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Hypothesis" } },
          "count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "HypothesisDetail": {
        "type": "object",
        "required": ["data"],
        "properties": { "data": { "$ref": "#/components/schemas/Hypothesis" } },
        "additionalProperties": false
      },
      "ProductCreateRequest": {
        "type": "object",
        "required": ["name", "category", "price"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": ["ropa", "herramientas", "outdoor"] },
          "price": { "type": "number", "exclusiveMinimum": 0 }
        },
        "additionalProperties": false
      },
      "ProductCreateResponse": {
        "type": "object",
        "required": ["data", "created"],
        "properties": {
          "data": { "$ref": "#/components/schemas/Product" },
          "created": { "const": true }
        },
        "additionalProperties": false
      },
      "MemberCreateRequest": {
        "type": "object",
        "required": ["name", "email", "terms"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "email": { "type": "string", "format": "email" },
          "experience": { "type": "string", "enum": ["inicial", "intermedio", "avanzado"] },
          "terms": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "MemberCreateResponse": {
        "type": "object",
        "required": ["data", "created"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["id", "name", "email"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 2 },
              "email": { "type": "string", "format": "email" },
              "experience": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          },
          "created": { "const": true }
        },
        "additionalProperties": false
      },
      "HypothesisCreateRequest": {
        "type": "object",
        "required": ["ingredient_ids", "objective"],
        "properties": {
          "ingredient_ids": {
            "type": "array",
            "minItems": 2,
            "maxItems": 6,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "objective": { "$ref": "#/components/schemas/HypothesisObjective" }
        },
        "additionalProperties": false
      },
      "IngredientValidation": {
        "type": "object",
        "required": ["position", "id", "name", "valid", "errors"],
        "properties": {
          "position": { "type": "integer", "minimum": 0 },
          "id": {},
          "name": { "type": ["string", "null"] },
          "valid": { "type": "boolean" },
          "errors": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "HypothesisMutation": {
        "type": "object",
        "required": ["data", "created", "duplicate", "duplicate_count", "validation"],
        "properties": {
          "data": { "$ref": "#/components/schemas/Hypothesis" },
          "created": { "type": "boolean" },
          "duplicate": { "type": "boolean" },
          "duplicate_count": { "type": "integer", "minimum": 0 },
          "validation": {
            "type": "object",
            "required": ["valid", "ingredients"],
            "properties": {
              "valid": { "const": true },
              "ingredients": { "type": "array", "items": { "$ref": "#/components/schemas/IngredientValidation" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "HypothesisValidationError": {
        "type": "object",
        "required": ["error", "validation"],
        "properties": {
          "error": { "type": "string", "minLength": 1 },
          "validation": {
            "type": "object",
            "required": ["valid"],
            "properties": {
              "valid": { "const": false },
              "errors": { "type": "array", "items": { "type": "string" } },
              "ingredients": { "type": "array", "items": { "$ref": "#/components/schemas/IngredientValidation" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "ResetResponse": {
        "type": "object",
        "required": ["reset", "seedVersion", "message"],
        "properties": {
          "reset": { "const": true },
          "seedVersion": { "type": "string" },
          "message": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": { "error": { "type": "string", "minLength": 1 } },
        "additionalProperties": false
      },
      "DetailedError": {
        "type": "object",
        "required": ["error", "detail"],
        "properties": {
          "error": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  }
}
