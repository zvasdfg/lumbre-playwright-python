      "${1:locator}.select_option(${2:value})"
    ]
  },
  "Playwright scoped dialog": {
    "scope": "python",
    "prefix": "pw-dialog",
    "description": "Create a dialog locator and scope a child control",
    "body": [
      "${1:dialog} = page.get_by_role(\"dialog\", name=${2:dialog_name})",
      "${3:control} = ${1:dialog}.get_by_label(${4:label})"
    ]
  },
  "Playwright component object": {
    "scope": "python",
    "prefix": "pw-component",
    "description": "Create a Component Object structure",
    "body": [
      "from __future__ import annotations",
      "",
      "from playwright.sync_api import Locator, Page",
      "",
      "",
      "class ${1:ExampleComponent}:",
      "    def __init__(self, page: Page) -> None:",
      "        self.root = page.get_by_role(\"${2:region}\", name=\"${3:Component}\")",
      "",
      "    def item_named(self, name: str) -> Locator:",
      "        return self.root.get_by_text(name, exact=True)"
    ]
  }
}
